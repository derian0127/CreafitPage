# Número WhatsApp Business (solo dígitos, código de país sin +)
# Debe coincidir con <meta name="creafit-whatsapp" content="..."> en la landing (index.html raíz).
VITE_WHATSAPP_NUMBER=573001557404

# URL pública del sitio (sin barra final). Se usa al generar sitemap.xml y robots.txt en `pnpm build`.
VITE_SITE_URL=https://tudominio.com

# Newsletter: abre esta URL en una pestaña nueva (p. ej. Google Forms o Tally).
# VITE_NEWSLETTER_FORM_URL=https://docs.google.com/forms/...

# Si no hay formulario, se puede usar mailto con esta dirección:
# VITE_CONTACT_EMAIL=hola@creafit.com
